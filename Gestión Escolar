<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SullyBec | Panel Administrativo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/lucide-static@0.321.0/font/lucide.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
        
        :root {
            --verde-agua: #2D8B7D; 
            --rosa-fondo: #FDF4F0;
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: var(--rosa-fondo); 
            color: #1E293B;
        }

        .sidebar {
            background: white;
            border-right: 1px solid #E2E8F0;
            height: 100vh;
            position: sticky;
            top: 0;
        }

        .student-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            border: 1px solid transparent;
        }

        .student-card:hover {
            transform: translateX(8px);
            background: white;
            border-color: var(--verde-agua);
            box-shadow: 0 10px 30px -10px rgba(45, 139, 125, 0.1);
        }

        .student-card.active {
            background: white;
            border-color: var(--verde-agua);
            ring: 2px solid var(--verde-agua);
        }

        .btn-beca {
            padding: 0.75rem;
            border-radius: 1rem;
            font-weight: 800;
            font-size: 0.75rem;
            transition: all 0.2s;
            background: #F8FAFC;
            color: #94A3B8;
        }

        .btn-beca.active {
            background: var(--verde-agua);
            color: white;
            box-shadow: 0 4px 12px rgba(45, 139, 125, 0.3);
        }

        .recibo-modal {
            background: white;
            border-radius: 3rem;
            border-top: 12px solid var(--verde-agua);
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 10px; }

        .loading-overlay {
            position: fixed;
            inset: 0;
            background: var(--rosa-fondo);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
        }
    </style>
</head>
<body class="flex">

    <!-- Loading Screen -->
    <div id="loading" class="loading-overlay">
        <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-[#2D8B7D] mb-4"></div>
        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#2D8B7D]">Sincronizando Base de Datos...</p>
    </div>

    <!-- Sidebar -->
    <aside class="sidebar w-20 lg:w-64 p-6 hidden md:flex flex-col">
        <div class="mb-10 text-center">
            <div class="w-12 h-12 bg-teal-50 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-[#2D8B7D]">
                <i class="lucide-settings text-[#2D8B7D]"></i>
            </div>
            <p class="hidden lg:block font-black text-[#2D8B7D] text-[10px] uppercase tracking-widest">Panel Académico</p>
        </div>
        <nav class="space-y-2">
            <div class="p-4 bg-[#2D8B7D] text-white rounded-2xl flex items-center gap-3 shadow-lg shadow-teal-900/20">
                <i class="lucide-users"></i>
                <span class="hidden lg:block font-bold text-xs uppercase tracking-wider">Alumnos</span>
            </div>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-4 md:p-10 max-w-7xl mx-auto w-full">
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10">
            <div>
                <h1 class="text-3xl font-black text-slate-800 tracking-tighter uppercase leading-none">Gestión de Alumnos</h1>
                <p class="text-teal-600 font-bold text-[10px] uppercase tracking-[0.2em] mt-2">SullyBec Instituto • Administradora</p>
            </div>
            <div class="relative w-full md:w-80">
                <i class="lucide-search absolute left-4 top-3.5 text-slate-300"></i>
                <input type="text" id="searchInput" placeholder="Buscar por nombre o ID..." class="w-full pl-12 pr-4 py-3.5 bg-white border border-slate-100 rounded-2xl shadow-sm outline-none font-semibold focus:ring-2 focus:ring-[#2D8B7D]">
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- List -->
            <div id="studentList" class="lg:col-span-7 space-y-3">
                <!-- Se llena con JS -->
            </div>

            <!-- Detail -->
            <div class="lg:col-span-5">
                <div id="detailView" class="hidden sticky top-10">
                    <div class="bg-white p-8 rounded-[3rem] shadow-xl border border-white">
                        <div class="text-center mb-8">
                            <div id="detPhoto" class="w-24 h-24 mx-auto bg-teal-50 rounded-[2.5rem] flex items-center justify-center border-4 border-white shadow-md mb-4 overflow-hidden text-[#2D8B7D] font-black text-2xl">
                                SB
                            </div>
                            <h3 id="detName" class="font-black text-2xl text-slate-800 tracking-tight">Nombre del Alumno</h3>
                            <p id="detCourse" class="text-[10px] font-bold text-teal-500 uppercase tracking-widest mt-1">Diplomado</p>
                        </div>

                        <div class="space-y-6">
                            <div>
                                <label class="text-[9px] font-black text-slate-400 uppercase mb-4 block text-center tracking-widest">Asignar Beca Académica</label>
                                <div class="grid grid-cols-4 gap-2" id="becaButtons">
                                    <button onclick="updateBeca(0)" class="btn-beca" data-val="0">0%</button>
                                    <button onclick="updateBeca(10)" class="btn-beca" data-val="10">10%</button>
                                    <button onclick="updateBeca(25)" class="btn-beca" data-val="25">25%</button>
                                    <button onclick="updateBeca(50)" class="btn-beca" data-val="50">50%</button>
                                </div>
                            </div>

                            <div class="pt-6 border-t border-slate-50 space-y-3">
                                <button onclick="openModal()" class="w-full bg-[#2D8B7D] text-white py-4 rounded-2xl font-black text-[10px] tracking-widest flex items-center justify-center gap-3 shadow-lg shadow-teal-900/10 hover:brightness-110">
                                    <i class="lucide-receipt"></i> VISTA PREVIA RECIBO
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="emptyState" class="p-12 text-center text-slate-300 border-2 border-dashed border-slate-200 rounded-[3rem] bg-white/50 flex flex-col items-center justify-center h-64">
                    <i class="lucide-user-circle text-5xl mb-4 opacity-20"></i>
                    <p class="font-bold uppercase text-[9px] tracking-widest max-w-[200px]">Selecciona un alumno para gestionar su beca</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal Recibo -->
    <div id="modal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden items-center justify-center p-4 z-50">
        <div class="recibo-modal w-full max-w-md p-10 relative shadow-2xl">
            <button onclick="closeModal()" class="absolute top-6 right-8 text-slate-300 text-3xl hover:text-slate-800">&times;</button>
            
            <div class="text-center mb-8">
                <h1 class="text-[#2D8B7D] font-black text-2xl tracking-tighter uppercase">SullyBec Instituto</h1>
                <p class="text-[9px] font-black text-slate-400 tracking-[0.3em] uppercase">Comprobante Administrativo</p>
            </div>

            <div class="space-y-4 mb-8 bg-slate-50/50 p-6 rounded-3xl border border-slate-100">
                <div class="flex justify-between border-b border-slate-100 pb-2">
                    <span class="text-slate-400 font-bold uppercase text-[9px]">Alumno:</span>
                    <span id="modName" class="font-black text-slate-800 text-xs">-</span>
                </div>
                <div class="flex justify-between border-b border-slate-100 pb-2">
                    <span class="text-slate-400 font-bold uppercase text-[9px]">ID Único:</span>
                    <span id="modId" class="font-black text-teal-600 text-xs">-</span>
                </div>
                
                <div class="mt-4">
                    <div class="flex justify-between text-[10px] font-bold text-slate-500">
                        <span>Monto Base:</span>
                        <span id="modBase">$0.00</span>
                    </div>
                    <div id="modBecaRow" class="flex justify-between text-[10px] font-black text-teal-600 hidden">
                        <span>Beca Aplicada:</span>
                        <span id="modBecaVal">-$0.00</span>
                    </div>
                    <div class="flex justify-between items-center pt-4 mt-2 border-t border-white">
                        <span class="text-[10px] font-black text-slate-800 uppercase italic">Total Final:</span>
                        <span id="modTotal" class="text-4xl font-black text-[#2D8B7D] tracking-tighter">$0.00</span>
                    </div>
                </div>
            </div>

            <p class="text-[9px] text-teal-800 leading-relaxed italic font-medium p-4 bg-teal-50/50 rounded-2xl mb-8">
                Este documento certifica el pago académico. <span class="font-black uppercase">No hay devoluciones.</span>
            </p>

            <button class="w-full bg-[#2D8B7D] text-white py-5 rounded-2xl font-black text-[10px] tracking-widest flex items-center justify-center gap-3 shadow-xl">
                <i class="lucide-download"></i> GUARDAR PDF
            </button>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, collection, doc, onSnapshot, updateDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyCcAda5-ewiR78bfLyYrjEMhfdc0RFxd7s",
            authDomain: "finanzas-escuela.firebaseapp.com",
            projectId: "finanzas-escuela",
            storageBucket: "finanzas-escuela.firebasestorage.app",
            messagingSenderId: "106864276061",
            appId: "1:106864276061:web:cc8b26cca0ef07088f13b4"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);
        const appId = 'finanzas-escuela';

        let students = [];
        let selectedStudent = null;

        // Inicializar
        async function init() {
            await signInAnonymously(auth);
            const q = collection(db, 'artifacts', appId, 'public', 'data', 'students');
            
            onSnapshot(q, (snapshot) => {
                students = snapshot.docs.map(d => ({ id: d.id, ...d.data() }));
                renderList();
                document.getElementById('loading').classList.add('hidden');
                
                // Actualizar detalle si hay uno seleccionado
                if(selectedStudent) {
                    selectedStudent = students.find(s => s.id === selectedStudent.id);
                    updateDetailUI();
                }
            });
        }

        function renderList() {
            const container = document.getElementById('studentList');
            const term = document.getElementById('searchInput').value.toLowerCase();
            
            const filtered = students.filter(s => 
                s.nombre?.toLowerCase().includes(term) || 
                s.id?.toLowerCase().includes(term)
            );

            container.innerHTML = filtered.map(s => `
                <div class="student-card p-5 rounded-3xl bg-white flex items-center justify-between ${selectedStudent?.id === s.id ? 'active translate-x-2' : ''}" onclick="selectStudent('${s.id}')">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl bg-teal-50 flex items-center justify-center font-black text-[#2D8B7D]">
                            ${s.nombre?.charAt(0)}
                        </div>
                        <div>
                            <p class="font-black text-slate-800 text-sm leading-none mb-1">${s.nombre}</p>
                            <p class="text-[9px] text-slate-400 font-bold uppercase tracking-widest">ID: ${s.id}</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <p class="font-black text-[#2D8B7D]">$${calculateTotal(s.costo, s.beca).toFixed(2)}</p>
                        ${s.beca > 0 ? `<span class="text-[8px] bg-teal-100 text-teal-700 px-2 py-0.5 rounded-full font-bold">BECA ${s.beca}%</span>` : ''}
                    </div>
                </div>
            `).join('');
        }

        window.selectStudent = (id) => {
            selectedStudent = students.find(s => s.id === id);
            document.getElementById('detailView').classList.remove('hidden');
            document.getElementById('emptyState').classList.add('hidden');
            renderList();
            updateDetailUI();
        };

        function updateDetailUI() {
            if(!selectedStudent) return;
            document.getElementById('detName').innerText = selectedStudent.nombre;
            document.getElementById('detCourse').innerText = selectedStudent.diplomado || 'Diplomado Académico';
            
            // Actualizar botones de beca
            document.querySelectorAll('.btn-beca').forEach(btn => {
                const val = parseInt(btn.dataset.val);
                btn.className = `btn-beca ${selectedStudent.beca === val ? 'active' : ''}`;
            });

            if(selectedStudent.photo) {
                document.getElementById('detPhoto').innerHTML = `<img src="${selectedStudent.photo}" class="w-full h-full object-cover">`;
            } else {
                document.getElementById('detPhoto').innerText = selectedStudent.nombre.charAt(0);
            }
        }

        window.updateBeca = async (val) => {
            if(!selectedStudent) return;
            const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'students', selectedStudent.id);
            await updateDoc(docRef, { beca: val });
        };

        function calculateTotal(monto, beca) {
            const base = typeof monto === 'string' ? parseFloat(monto.replace(/[^0-9.]/g, '')) : (monto || 0);
            return base - (base * (beca || 0) / 100);
        }

        window.openModal = () => {
            if(!selectedStudent) return;
            document.getElementById('modName').innerText = selectedStudent.nombre;
            document.getElementById('modId').innerText = selectedStudent.id;
            document.getElementById('modBase').innerText = `$${selectedStudent.costo}`;
            
            const becaMonto = (selectedStudent.costo * (selectedStudent.beca || 0) / 100);
            if(selectedStudent.beca > 0) {
                document.getElementById('modBecaRow').classList.remove('hidden');
                document.getElementById('modBecaVal').innerText = `-$${becaMonto.toFixed(2)}`;
            } else {
                document.getElementById('modBecaRow').classList.add('hidden');
            }

            document.getElementById('modTotal').innerText = `$${calculateTotal(selectedStudent.costo, selectedStudent.beca).toFixed(2)}`;
            document.getElementById('modal').style.display = 'flex';
        };

        window.closeModal = () => {
            document.getElementById('modal').style.display = 'none';
        };

        document.getElementById('searchInput').addEventListener('input', renderList);

        init();
    </script>
</body>
</html>
